# --- Database (Neon Postgres via Vercel Marketplace) ---
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# --- Auth.js (Google sign-in, single user) ---
# Generate a secret with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-me"
AUTH_GOOGLE_ID="xxxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="xxxxx"
# Only this Google account may sign in:
OWNER_EMAIL="you@gmail.com"

# --- Local agent ingest auth (shared secret; must match agent.json deviceToken) ---
AGENT_TOKEN="generate-a-long-random-string"
